# GEMINI_API_KEY: Required for /api/music (Vercel serverless / vercel dev).
# Do not use a VITE_ prefix; the key must stay server-side only.
# Set the same variable in your Vercel project: Settings → Environment Variables.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# BLOB_READ_WRITE_TOKEN: Create a Blob store in the Vercel dashboard, then add this token.
# Required in production for full-length tracks (audio is uploaded to Blob; JSON stays small).
# Without it, /api/music falls back to inline base64 (4 MB decoded max).
# https://vercel.com/docs/storage/vercel-blob
# BLOB_READ_WRITE_TOKEN="vercel_blob_..."

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
